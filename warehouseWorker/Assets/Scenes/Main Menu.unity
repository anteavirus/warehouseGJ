  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041A\u041E\u0420\u041E\u0422\u041A\u041E\u0415 \u0423\u0412\u0415\u0414\u041E\u041C\u041B\u0415\u041D\u0418\u0415
    \u041E\u0411 \u041E\u0422\u0427\u0423\u0416\u0414\u0415\u041D\u0418\u0418 \u041F\u0420\u0410\u0412:\r\n\u041F\u0443\u0442\u0435\u043C
    \u043F\u0440\u0438\u043D\u044F\u0442\u0438\u044F 5 \u043F\u0435\u043D\u043D\u0438/\u0433\u043E\u0434
    \u0432\u044B \u0441\u043E\u0433\u043B\u0430\u0448\u0430\u0435\u0442\u0435\u0441\u044C:\r\n-
    \u0441\u0442\u0430\u0442\u044C \u043D\u0435\u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u0430 \xAB\u0430\u043B\u044C\u0444\u0430-\u0442\u0435\u0441\u0442\u043E\u0432\u044B\u043C
    \u0441\u0443\u0431\u044A\u0435\u043A\u0442\u043E\u043C\xBB \u0441 \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043E\u0448\u0435\u0439\u043D\u0438\u043A\u043E\u043C, \u0442\u0435\u043A\u0442\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0434\u0437\u044E\u0434\u043E \u0438 \u043B\u0430\u043C\u043F\u043E\u0447\u043A\u0430\u043C\u0438,
    \u043D\u0430\u0440\u0443\u0448\u0430\u044E\u0449\u0438\u043C\u0438 \u0432\u0430\u0448\u0435
    \u0437\u0434\u0440\u0430\u0432\u043E\u043C\u044B\u0441\u043B\u0438\u0435;\r\n-
    \u043D\u0435 \u0432\u043E\u0437\u043C\u0443\u0449\u0430\u0442\u044C\u0441\u044F,
    \u043A\u043E\u0433\u0434\u0430 \u0430\u043D\u043E\u043C\u0430\u043B\u0438\u0438
    \u0437\u0430\u0431\u0435\u0440\u0443\u0442 \u0432\u0430\u0448\u0438 \u0434\u0435\u043D\u044C\u0433\u0438,
    \u0441\u0430\u043D\u0442\u0435\u0445\u043D\u0438\u043A \u0411\u043E\u0431 - \u043E\u0441\u0442\u0430\u0442\u043A\u0438
    \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0430, \u0430 \u0437\u0430\u043A\u043E\u043D\u044B
    \u0444\u0438\u0437\u0438\u043A\u0438 - \u0432\u0430\u0448\u0438 \u043D\u043E\u0441\u043A\u0438."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 18b380b9a0bcdbb408b819886c51f761, type: 2}
