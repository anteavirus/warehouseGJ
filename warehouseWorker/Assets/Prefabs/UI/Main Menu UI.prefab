  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0447\u0451\u0440\u0442. \u044F \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u0447\u0442\u043E\u0431\u044B
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u044D\u0442\u0443
    \u0448\u0443\u0442\u043A\u0443 \u0437\u0434\u0435\u0441\u044C \u0434\u043E\u043B\u0436\u043D\u043E
    \u0431\u044B\u0442\u044C \u0434\u043E\u0444\u0438\u0433\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u043D\u043E \u043F\u043E\u043A\u0430-\u0447\u0442\u043E \u0443 \u043D\u0430\u0441
    \u0442\u043E\u043B\u044C\u043A\u043E \u044D\u0442\u043E\u0442 \u0447\u0435\u0440\u0442\u043E\u0432
    \u043B\u0438\u0434\u0435\u0440\u0431\u043E\u0440\u0434 \u0435\u0441\u0442\u044C.
    \u0410 \u043C\u044B \u0435\u0449\u0451 \u0445\u043E\u0442\u0438\u043C \u043A\u0430\u043A-\u0442\u043E
    \u0414\u041E\u0421\u0422\u0418\u0416\u0415\u041D\u0418\u042F \u0441\u0434\u0435\u043B\u0430\u0442\u044C!
    \u0423\u0436\u0430\u0441... \u041D\u0435, \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u043D\u0438 \u0435\u0441\u0442\u044C, \u043D\u043E \u0449\u0430\u0441
    \u043C\u043D\u0435 \u0435\u0449\u0451 \u0432\u0441\u044E \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0438\u0433\u0440\u0443 \u0434\u043E\u0434\u0435\u043B\u044B\u0432\u0430\u0442\u044C."
  m_isRightToLeft: 0
