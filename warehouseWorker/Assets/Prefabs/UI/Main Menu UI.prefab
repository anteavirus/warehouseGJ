  m_text: "\u041A\u043E\u043C\u0430\u043D\u0434\u0430 \u041F\u043E\u0434\u0437\u0430\u0431\u043E\u0440\u043D\u044B\u0445
    \u0422\u0440\u043E\u043B\u043B\u0435\u0439, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0447\u0435\u0442\u044B\u0440\u0435 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u0430.
    \n\n\u041E\u043B\u0435\u0433 \u041D\u0438\u043A\u0438\u0444\u043E\u0440\u043E\u0432
    - \u0417\u0432\u0443\u043A\u043E\u0432\u043E\u0439 \u0434\u0438\u0437\u0430\u0439\u043D\u0435\u0440\n\u042F\u0440\u043E\u0441\u043B\u0430\u0432\u0430
    \u0411\u0435\u043B\u044F\u0435\u0432\u0430 - 3\u0434 \u043C\u043E\u0434\u0435\u043B\u044C\u0435\u0440
    + \u0442\u0435\u043A\u0441\u0442\u0443\u0440\u043E\u0434\u0435\u043B\n\u0418\u043B\u044C\u044F
    \u0412\u0430\u0440\u0430\u043D\u043A\u0438\u043D - \u041F\u041C \u0438 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u043C\u043D\u043E\u0433\u043E \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0434\u0435\u043B \u0442\u0430\u043C \u0434\u0430 \u0441\u044F\u043C \u0434\u043B\u044F
    \u043F\u0435\u0440\u0435\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\n\u041A\u043E\u043D\u043E\u0432\u0430\u043B\u043E\u0432
    \u0421\u0435\u0440\u0433\u0435\u0439 - \u043A\u043E\u0434\u0435\u0440 \u0438
    \u043C\u0430\u0441\u0442\u0435\u0440 \u043D\u0430 \u0432\u0441\u0435 \u0440\u0443\u0447\u043A\u0438.
    (\u042D\u0442\u0438 \u0441\u0442\u0440\u0430\u0448\u043D\u044B\u0435 \u0430\u043D\u0438\u043C\u0430\u0446\u0438\u0438
    - \u043C\u043E\u0438)"
