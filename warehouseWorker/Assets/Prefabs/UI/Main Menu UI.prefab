  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E \u043D\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E, \u0441\u043A\u043E\u0440\u0435\u0435
    \u0434\u0430\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0443\u0435\u043C\u043E;
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0435\u0435 \u0431\u0443\u0434\u0435\u0442
    \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u043A\u0430\u043A \u043D\u0438\u043A\u0442\u043E
    \u044D\u0442\u043E \u043E\u043A\u043D\u043E \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442.\n\u041C\u043E\u043B\u044E\u0441\u044C
    \u0447\u0442\u043E \u044D\u0442\u043E \u043D\u0435 \u043B\u043E\u043C\u0430\u0435\u0442
    \u0438\u0433\u0440\u0443, \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0443
    \u043D\u0435\u0434\u043E\u043F\u043E\u043D\u044F\u0442\u043D\u0443\u044E.\n\u0415\u0441\u043B\u0438
    \u0432\u0441\u0451 \u0436\u0435 \u043B\u043E\u043C\u0430\u0435\u0442 \u0438\u0433\u0440\u0443
    - \u043F\u043D\u0438\u0442\u0435 \u043C\u0435\u043D\u044F - \u043A\u043E\u0434\u0435\u0440\u0430
    - \u043D\u0430 @KonovalovSergeyAnTeaVirus"
  m_isRightToLeft: 0
