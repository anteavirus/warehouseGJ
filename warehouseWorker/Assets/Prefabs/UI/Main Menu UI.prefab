  m_text: "\u041E\u0434\u043D\u043E \u0441\u043B\u043E\u0432\u043E - \u0410\u041C\u0411\u0418\u0426\u0418\u041E\u0417\u041D\u041E\u0421\u0422\u042C.
    \u0421\u043B\u0438\u0448\u043A\u043E\u043C \u043C\u043D\u043E\u0433\u043E \u0447\u0435\u0433\u043E
    \u043C\u044B \u0437\u0430\u0434\u0443\u043C\u0430\u043B\u0438 \u0434\u043B\u044F
    \u0434\u0432\u0443\u0445 \u043D\u0435\u0434\u0435\u043B\u044C. \u0427\u0430\u0441\u0442\u044C
    \u043F\u0440\u0438\u043A\u043E\u043B\u043E\u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u044B \u0441\u0434\u0435\u043B\u0430\u043B\u0438 \u043B\u0438\u0431\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u043D\u0430 \u0431\u0430\u0437\u043E\u0432\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435, \u043B\u0438\u0431\u043E \u043A\u0430\u043A
    \u043C\u0438\u0448\u0443\u0440\u0430 - \u043A\u0440\u0430\u0441\u0438\u0432\u0435\u043D\u044C\u043A\u043E,
    \u043C\u0435\u0448\u0430\u0435\u0442\u0441\u044F, \u043D\u043E \u043D\u0435 \u0431\u043E\u043B\u0435\u0435."
